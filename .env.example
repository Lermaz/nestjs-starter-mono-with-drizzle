JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d
BCRYPT_ROUNDS=10
# MikroORM (current runtime) — remove after Drizzle migration
DATABASE_URL=sqlite://./data/app.db

# Drizzle + PostgreSQL (target) — use with `pnpm db:*` and docker compose postgres
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app
# CORS_ORIGINS=http://localhost:5173
# ENABLE_SWAGGER=true
